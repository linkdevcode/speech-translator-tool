# Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override default gemini-3-flash-preview
# GEMINI_MODEL=gemini-3-flash-preview

# Groq API key (https://console.groq.com) — used when Gemini hits quota/rate limit
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq model (default llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Edge TTS volume boost (default +35%, e.g. +50% for louder)
# TTS_VOLUME=+35%
